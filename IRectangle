using System;

namespace GeoCalcPro
{
    public class Rectangle : Figure
    {
        public double Width { get; set; }
        public double Height { get; set; }

        public Rectangle(string name, string color, double width, double height) : base(name, color)
        {
            if (width <= 0 || height <= 0)
                throw new ArgumentException("Ширина и высота должны быть положительными.");
            Width = width;
            Height = height;
        }

        public override double GetArea() => Width * Height;
        public override double GetPerimeter() => 2 * (Width + Height);

        public override string GetInfo() =>
            base.GetInfo() + $", Ширина: {Width:F2}, Высота: {Height:F2}";
    }
}
